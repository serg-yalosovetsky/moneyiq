<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — Compose handles the full Material3 theming.
         This is only the XML "shell" needed by the window/activity before
         Compose takes over. -->
    <style name="Theme.MoneyIQ" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
